---
import Base from '../layouts/Base.astro';
import { profile } from '../data/profile';
---

<Base title="Activities" description={`${profile.name} 활동 이력`}>
  <div class="page wrap">
    <p class="cli-label">history</p>
    <h1 class="page-title">Activities</h1>
    <p class="lede">교육·연구·수상·대외 활동 이력입니다.</p>
    <section class="awards">
      <p class="cli-label">ls awards/</p>
      <ul class="award-list">
        {
          profile.awards.map((a) => (
            <li>
              <div class="a-title">{a.title}</div>
              <div class="a-by">
                {a.by} · {a.date}
              </div>
            </li>
          ))
        }
      </ul>
    </section>
    <p class="cli-label">history --all</p>
    <div>
      <ul class="timeline">
        {
          profile.timeline.map((t) => (
            <li class={t.current ? 'current' : undefined}>
              <div class="period">{t.period}</div>
              <div class="t-title">{t.title}</div>
              <div class="t-detail">{t.detail}</div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Base>
