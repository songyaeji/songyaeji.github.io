---
import Base from '../layouts/Base.astro';
import { profile } from '../data/profile';
---

<Base title="Activities" description={`${profile.name} 활동 이력`}>
  <div class="page wrap">
    <p class="cli-label">history --all</p>
    <h1 class="page-title">Activities</h1>
    <div>
      <ul class="timeline">
        {
          profile.timeline.map((t) => (
            <li class={t.current ? 'current' : undefined}>
              <div class="period">{t.period}</div>
              <div class="t-title">{t.title}</div>
              <div class="t-detail">{t.detail}</div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Base>
