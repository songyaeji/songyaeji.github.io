---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NowPanel from '../components/NowPanel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { profile } from '../data/profile';

const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Base>
  <section class="hero">
    <div>
      <p class="eyebrow">{profile.affiliation}</p>
      <h1>
        {profile.name}<span class="name-ko" lang="ko">{profile.nameKo}</span>
      </h1>
      <p class="role">{profile.tagline}</p>
      <p class="intro">
        {profile.school} 재학. AI·LLM 공급망 보안과 취약점 분석을 연구합니다. 지금은
        MCP(Model Context Protocol) 생태계의 공급망 위협을 탐지하는 연구에 집중하고 있습니다.
      </p>
      <div class="hero-links">
        <a class="btn btn-primary" href={`mailto:${profile.contact.email}`}>Contact</a>
        <a class="btn" href={profile.contact.github}>GitHub</a>
        <a class="btn" href="/about/">CV & About</a>
      </div>
    </div>
    <NowPanel />
  </section>

  <section>
    <div class="section-head">
      <h2>Activity</h2>
    </div>
    <div class="activity-card">
      <img
        src={`https://ghchart.rshah.org/2456c9/${profile.handle}`}
        alt={`${profile.handle}의 최근 1년 GitHub 기여 그래프`}
        loading="lazy"
      />
      <p class="caption">
        <span>GitHub contributions, last 12 months</span>
        <a href={profile.contact.github}>github.com/{profile.handle} →</a>
      </p>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Featured Projects</h2>
      <a class="more" href="/projects/">All projects →</a>
    </div>
    <ul class="card-grid">
      {featured.map((p) => <ProjectCard project={p} />)}
    </ul>
  </section>
</Base>
