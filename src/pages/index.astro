---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NowPanel from '../components/NowPanel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { profile } from '../data/profile';

const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Base>
  <h1 class="article-title">About Me</h1>

  <section class="prose">
    {profile.bio.map((p) => <p>{p}</p>)}
  </section>

  <section>
    <NowPanel />
  </section>

  <section class="info-cols">
    <div class="info-col">
      <h2>Interests</h2>
      <ul class="interest-list">
        {profile.interests.map((i) => <li>{i}</li>)}
      </ul>
    </div>
    <div class="info-col">
      <h2>Education</h2>
      <ul class="edu-list">
        {
          profile.education.map((e) => (
            <li>
              <div class="degree">{e.degree}</div>
              <div class="school">{e.school}</div>
              <div class="period">{e.period}</div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Activity</h2>
    </div>
    <div class="activity-card">
      <img
        src={`https://ghchart.rshah.org/b45309/${profile.handle}`}
        alt={`${profile.handle}의 최근 1년 GitHub 기여 그래프`}
        loading="lazy"
      />
      <p class="caption">
        <span>GitHub contributions, last 12 months</span>
        <a href={profile.contact.github}>github.com/{profile.handle} →</a>
      </p>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Featured Projects</h2>
      <a class="more" href="/projects/">All projects →</a>
    </div>
    <ul class="card-grid">
      {featured.map((p) => <ProjectCard project={p} />)}
    </ul>
  </section>
</Base>
