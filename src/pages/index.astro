---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NowPanel from '../components/NowPanel.astro';
import { profile } from '../data/profile';

const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

// 최신 보안동향 카드뉴스 회차 — 없으면(첫 발행 전) 홈에 표시 안 함
const trendIssues = await getCollection('trend');
const latestTrend = trendIssues.sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
---

<Base>
  <div class="home-grid wrap">
    <aside class="profile">
      <img
        class="avatar"
        src={profile.avatar}
        alt={`${profile.name} 프로필 사진`}
        width="108"
        height="108"
      />
      <div>
        <h1 class="name">{profile.name}<span class="ko" lang="ko">{profile.nameKo}</span></h1>
        <p class="role">{profile.tagline}</p>
      </div>
      <ul class="contact-rows">
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2.5" y="4.5" width="19" height="15" rx="2.5"/><path d="m3 6 9 7 9-7"/></svg>
          <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.1.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.58 9.58 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"/></svg>
          <a href={profile.contact.github}>github.com/{profile.handle}</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg>
          <span>{profile.location}</span>
        </li>
      </ul>
      <NowPanel />
      {
        latestTrend && (
          <a class="trend-line" href="/trend/">
            <span class="badge-new" aria-hidden="true">TREND</span>
            NO.{latestTrend.data.issue_no} — {latestTrend.data.date} daily briefing →
          </a>
        )
      }
    </aside>

    <div class="home-main">
      <section class="whoami">
        <p class="cli-line">
          <span class="ps1">$</span>
          <span class="typed" data-cmd="whoami"></span><span class="cursor" aria-hidden="true"></span>
        </p>
        <p class="statement">
          저는 <span class="mark">"한계를 뛰어넘기 위해 끊임없이 노력하는"</span> 보안 담당자입니다.
        </p>
      </section>

      <div class="home-row-2">
        <section>
          <p class="cli-label">cat interests.md</p>
          <ul class="interest-list">
            {profile.interests.map((i) => <li>{i}</li>)}
          </ul>
        </section>
        <section>
          <p class="cli-label">cat education.md</p>
          <ul class="edu-list">
            {
              profile.education.map((e) => (
                <li>
                  <div class="degree">{e.degree}</div>
                  <div class="school">{e.school}</div>
                  <div class="period">{e.period}</div>
                </li>
              ))
            }
          </ul>
        </section>
      </div>

      <section>
        <p class="cli-label">ls skills/</p>
        <div class="skills-inline">
          {
            Object.entries(profile.skills).map(([group, items]) => (
              <div class="row">
                <span class="group">{group}</span>
                <ul class="tags">
                  {items.map((s) => (
                    <li class="tag">{s}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section>
        <p class="cli-label">ls projects/ --featured</p>
        <ul class="mini-list">
          {
            featured.map((p) => (
              <li class="mini">
                <span class="t">
                  {p.data.repo ? <a href={p.data.repo}>{p.data.title}</a> : p.data.title}
                </span>
                <span class="d">{p.data.summary}</span>
                <span class="y">{p.data.year}</span>
              </li>
            ))
          }
          <li class="mini">
            <a href="/projects/">All projects →</a>
          </li>
        </ul>
      </section>
    </div>
  </div>

  <script is:inline>
    // 프로필 CLI 타이핑 — reduced-motion이면 즉시 표시
    (() => {
      const el = document.querySelector('.typed');
      if (!el) return;
      const cmd = el.dataset.cmd || '';
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.textContent = cmd;
        return;
      }
      let i = 0;
      const tick = () => {
        el.textContent = cmd.slice(0, ++i);
        if (i < cmd.length) setTimeout(tick, 90 + Math.random() * 90);
      };
      setTimeout(tick, 400);
    })();
  </script>
</Base>
