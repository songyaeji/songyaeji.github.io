---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NowPanel from '../components/NowPanel.astro';
import Icon from '../components/Icon.astro';
import { profile } from '../data/profile';

// 최신 보안동향 카드뉴스 회차 — 없으면(첫 발행 전) 홈에 표시 안 함
const trendIssues = await getCollection('trend');
const latestTrend = trendIssues.sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
---

<Base>
  <div class="home-grid wrap">
    <aside class="profile">
      <div class="identity">
        <img
          class="avatar"
          src={profile.avatar}
          alt={`${profile.name} 프로필 사진`}
          width="140"
          height="140"
        />
        <div>
          <h1 class="name">{profile.name}<span class="ko" lang="ko">{profile.nameKo}</span></h1>
          <p class="role">{profile.tagline}</p>
          <p class="loc"><Icon name="pin" size={13} /> {profile.location}</p>
        </div>
        <ul class="contact-icons">
          <li>
            <a href={`mailto:${profile.contact.email}`} aria-label="Email" title={profile.contact.email}>
              <Icon name="mail" size={17} />
            </a>
          </li>
          <li>
            <a href={profile.contact.github} aria-label="GitHub" title={`github.com/${profile.handle}`}>
              <Icon name="github" size={17} />
            </a>
          </li>
          <li>
            <a href={profile.contact.lab} aria-label="SIFT Lab" title="SIFT Lab">
              <Icon name="external" size={17} />
            </a>
          </li>
        </ul>
      </div>
      <NowPanel />
      <div>
        <p class="cli-label">cat interests.md</p>
        <ul class="interest-list">
          {profile.interests.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      {
        latestTrend && (
          <a class="trend-line" href="/trend/">
            <span class="badge-new" aria-hidden="true">TREND</span>
            NO.{latestTrend.data.issue_no} — {latestTrend.data.date} daily briefing →
          </a>
        )
      }
    </aside>

    <div class="home-main">
      <section class="whoami">
        <p class="cli-line">
          <span class="ps1">$</span>
          <span class="typed" data-cmd="whoami"></span><span class="cursor" aria-hidden="true"></span>
        </p>
        <p class="statement">
          저는 <span class="mark">"한계를 뛰어넘기 위해 끊임없이 노력하는"</span> AI 보안 연구자입니다.
        </p>
        <p class="philosophy">{profile.philosophy}</p>
      </section>

      <div class="home-row-2">
        <section>
          <p class="cli-label">cat education_research.md</p>
          <p class="tile-group-label">School</p>
          <ul class="tile-list">
            {
              profile.education
                .filter((e) => e.type === 'school')
                .map((e) => (
                  <li class="tile tile-row">
                    <Icon name="cap" size={15} />
                    <div>
                      <div class="t-name">{e.degree}</div>
                      <div class="t-sub">{e.school}</div>
                      <div class="t-date">{e.period}</div>
                    </div>
                  </li>
                ))
            }
          </ul>
          <p class="tile-group-label">External</p>
          <ul class="tile-list">
            {
              profile.education
                .filter((e) => e.type === 'external')
                .map((e) => (
                  <li class="tile tile-row">
                    <Icon name="cap" size={15} />
                    <div>
                      <div class="t-name">{e.degree}</div>
                      <div class="t-sub">{e.school}</div>
                      <div class="t-date">{e.period}</div>
                    </div>
                  </li>
                ))
            }
          </ul>
        </section>
        <section>
          <p class="cli-label">ls awards/</p>
          <ul class="tile-list">
            {
              profile.awards.map((a) => (
                <li class="tile tile-row">
                  <Icon name="trophy" size={15} />
                  <div>
                    <div class="t-name">{a.title}</div>
                    <div class="t-sub">{a.by}</div>
                    <div class="t-date">{a.date}</div>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </div>

  <script is:inline>
    // 프로필 CLI 타이핑 — reduced-motion이면 즉시 표시
    (() => {
      const el = document.querySelector('.typed');
      if (!el) return;
      const cmd = el.dataset.cmd || '';
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.textContent = cmd;
        return;
      }
      let i = 0;
      const tick = () => {
        el.textContent = cmd.slice(0, ++i);
        if (i < cmd.length) setTimeout(tick, 90 + Math.random() * 90);
      };
      setTimeout(tick, 400);
    })();
  </script>
</Base>
