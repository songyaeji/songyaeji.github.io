---
import Base from '../layouts/Base.astro';
import { picks, pickSections, picksUpdated } from '../data/picks';

const [uy, um, ud] = picksUpdated.split('-');
const updatedLabel = `${uy}년 ${Number(um)}월 ${Number(ud)}일`;
---

<Base title="Picks" description="직접 써보고 추천하는 AI skills·MCP·tools·articles 모음">
  <div class="page wrap">
    <p class="cli-label">cat picks.md</p>
    <h1 class="page-title">Picks</h1>
    <p class="lede">직접 써보고 좋았던 AI skills · MCP · tools · articles 모음입니다.</p>
    <p class="picks-updated">
      <span class="cli-label">git log -1 --format=%cd</span>
      <time datetime={picksUpdated}>{updatedLabel}</time> 기준으로 고른 목록입니다.
    </p>
    <div class="pick-columns">
      {
        pickSections.map((s) => {
          // 별(important) 항목을 위로 — 같은 등급끼리는 원래 순서 유지(stable sort)
          const group = picks
            .filter((p) => p.category === s.key)
            .sort((a, b) => Number(b.important ?? false) - Number(a.important ?? false));
          return (
            <section class="pick-section" data-cat={s.key}>
              <p class="cli-label">{s.cmd}</p>
              <ul class="pick-list">
                {group.map((p) => (
                  <li class="pick" class:list={{ important: p.important }}>
                    {p.important && <span class="pick-star" aria-label="중요" title="중요">⭐</span>}
                    {p.link ? <a href={p.link} rel="noopener">{p.name}</a> : <span class="pick-name">{p.name}</span>}
                    {p.date && <span class="pick-date">{p.date}</span>}
                    <p class="pick-tagline">{p.tagline}</p>
                    <details>
                      <summary>why</summary>
                      <p class="pick-reason">{p.reason}</p>
                    </details>
                  </li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</Base>
