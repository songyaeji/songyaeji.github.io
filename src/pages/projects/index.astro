---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="Projects" description="보안 연구·개발 프로젝트 목록">
  <div class="page wrap">
    <p class="cli-label">ls projects/ --all</p>
    <h1 class="page-title">Projects</h1>
    <p class="lede">카드를 누르면 상세 내용이 펼쳐집니다.</p>
    <ul class="project-list">
      {projects.map((p) => <ProjectCard project={p} />)}
    </ul>
  </div>
</Base>

<script>
  // 아코디언 토글 — 요약행 클릭/키보드로 .open 전환, 상세는 max-height 트랜지션.
  // 제목 옆 GitHub 링크(data-no-toggle)는 토글하지 않고 링크만 동작
  document.querySelectorAll('.project-summary-row').forEach((row) => {
    const toggle = () => {
      const card = row.closest('.project-card');
      if (!card) return;
      const isOpen = card.classList.toggle('open');
      row.setAttribute('aria-expanded', String(isOpen));
    };
    row.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('[data-no-toggle]')) return;
      toggle();
    });
    // role="button"이라 Enter·Space로도 펼침
    row.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key !== 'Enter' && ke.key !== ' ') return;
      if ((ke.target as HTMLElement).closest('[data-no-toggle]')) return;
      ke.preventDefault();
      toggle();
    });
  });

  // 홈 스탯 등에서 /projects/#slug 로 진입하면 해당 카드를 펼치고 스크롤
  const target = location.hash && document.querySelector(`.project-card${location.hash}`);
  if (target) {
    target.classList.add('open');
    target.querySelector('.project-summary-row')?.setAttribute('aria-expanded', 'true');
    target.scrollIntoView({ block: 'start', behavior: 'smooth' });
  }
</script>
