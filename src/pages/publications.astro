---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';

const pubs = (await getCollection('research')).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order,
);
---

<Base title="Publications" description="논문 및 리서치 목록">
  <div class="page wrap">
    <p class="cli-label">ls publications/</p>
    <h1 class="page-title">Publications</h1>
    <div>
      <ul class="pub-list">
        {
          pubs.map((pub) => (
            <li class={`pub${pub.data.placeholder ? ' placeholder' : ''}`}>
              <span class="card-chip" aria-hidden="true">
                <Icon name="doc" size={16} />
              </span>
              <div class="pub-top">
                {/* in-preparation은 배지가 상태를 말하므로 venue 텍스트("In preparation") 중복 표기 생략 */}
                {pub.data.status !== 'in-preparation' && (
                  <span class="pub-venue">{pub.data.venue}</span>
                )}
                <span class="pub-year">{pub.data.year}</span>
                {pub.data.placeholder && <span class="badge badge-placeholder">Example</span>}
                {!pub.data.placeholder && pub.data.status === 'in-preparation' && (
                  <span class="badge badge-prep">In Preparation</span>
                )}
              </div>
              <div class="pub-title">
                {pub.data.title}
                {pub.data.links.pdf && (
                  <a
                    class="pub-title-link"
                    href={pub.data.links.pdf}
                    aria-label="논문 원문 (PDF/DOI)"
                    title="Paper (PDF/DOI)"
                  >
                    <Icon name="doc" size={15} />
                  </a>
                )}
              </div>
              {pub.data.authors.length > 0 && (
                <div class="pub-authors">{pub.data.authors.join(', ')}</div>
              )}
              <div class="pub-foot">
                {pub.data.tags.length > 0 && (
                  <ul class="tags">
                    {pub.data.tags.map((t) => (
                      <li class="tag">{t}</li>
                    ))}
                  </ul>
                )}
                {(pub.data.links.code || pub.data.links.slides) && (
                  <div class="icon-links">
                    {pub.data.links.code && (
                      <a href={pub.data.links.code} aria-label="코드 저장소" title="Code">
                        <Icon name="code" size={15} />
                      </a>
                    )}
                    {pub.data.links.slides && (
                      <a href={pub.data.links.slides} aria-label="발표 자료" title="Slides">
                        <Icon name="external" size={15} />
                      </a>
                    )}
                  </div>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Base>
