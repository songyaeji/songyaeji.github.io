---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const pubs = (await getCollection('research')).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order,
);
const hasExamples = pubs.some((p) => p.data.placeholder);
---

<Base title="Publications" description="논문 및 리서치 목록">
  <div class="page wrap">
    <p class="cli-label">ls publications/</p>
    <h1 class="page-title">Publications</h1>
    <p class="lede">
      논문·연구 산출물 목록입니다. <strong>In Preparation</strong>은 작성 중인 연구로, 게재 확정 시 갱신됩니다. 게재 논문은
      <a href="https://ieeexplore.ieee.org/author/551539848666305">IEEE Xplore 저자 프로필</a>과
      <a href="https://orcid.org/0009-0006-4733-9791">ORCID</a>에서도 확인할 수 있습니다.
      {
        hasExamples && (
          <>
            <strong>Example 배지가 붙은 항목은 레이아웃용 예시</strong>이며 실제 논문이 아닙니다.
          </>
        )
      }
    </p>
    <div>
      <ul class="pub-list">
        {
          pubs.map((pub) => (
            <li class={`pub${pub.data.placeholder ? ' placeholder' : ''}`}>
              <div class="pub-title">
                {pub.data.title}
                {pub.data.placeholder && <span class="badge badge-placeholder"> Example</span>}
                {!pub.data.placeholder && pub.data.status === 'in-preparation' && (
                  <span class="badge badge-prep"> In Preparation</span>
                )}
              </div>
              <div class="pub-venue">
                {pub.data.venue} · {pub.data.year}
              </div>
              {pub.data.authors.length > 0 && (
                <div class="pub-authors">{pub.data.authors.join(', ')}</div>
              )}
              {(pub.data.links.pdf || pub.data.links.code || pub.data.links.slides) && (
                <div class="pub-links">
                  {pub.data.links.pdf && <a href={pub.data.links.pdf}>PDF</a>}
                  {pub.data.links.code && <a href={pub.data.links.code}>Code</a>}
                  {pub.data.links.slides && <a href={pub.data.links.slides}>Slides</a>}
                </div>
              )}
              {pub.data.tags.length > 0 && (
                <ul class="tags">
                  {pub.data.tags.map((t) => (
                    <li class="tag">{t}</li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Base>
