---
import Base from '../layouts/Base.astro';
import { profile } from '../data/profile';
---

<Base title="About" description={`${profile.name} 이력·기술스택·연락처`}>
  <h1 class="page-title">About</h1>
  <p class="page-lede">
    {profile.school} · {profile.location}
  </p>

  <section>
    <div class="section-head"><h2>Timeline</h2></div>
    <ul class="timeline">
      {
        profile.timeline.map((t) => (
          <li class={t.current ? 'current' : undefined}>
            <div class="period">{t.period}</div>
            <div class="t-title">{t.title}</div>
            <div class="t-detail">{t.detail}</div>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <div class="section-head"><h2>Skills</h2></div>
    <div class="skills">
      {
        Object.entries(profile.skills).map(([group, items]) => (
          <div class="skill-group">
            <h3>{group}</h3>
            <ul class="tags">
              {items.map((s) => (
                <li class="tag">{s}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section>
    <div class="section-head"><h2>Contact</h2></div>
    <ul class="contact-list">
      <li>
        <span class="k">GitHub</span>
        <a href={profile.contact.github}>github.com/{profile.handle}</a>
      </li>
      <li>
        <span class="k">Email</span>
        <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
      </li>
      {
        profile.contact.linkedin !== '#' && (
          <li>
            <span class="k">LinkedIn</span>
            <a href={profile.contact.linkedin}>Profile</a>
          </li>
        )
      }
    </ul>
  </section>
</Base>
