---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, tags, year, repo, extLink, role, collaborators, highlights } =
  project.data;
const { Content } = await render(project);

// highlights는 렌더되지 않는 frontmatter 문자열이라 [링크]·**강조** 마크다운이
// 그대로 노출됐다 — 여기서만 앵커·strong으로 변환
const linkify = (text: string) =>
  text
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
---

<li class="project-card" id={project.id} data-cat={project.data.category}>
  <div
    class="project-summary-row"
    role="button"
    tabindex="0"
    aria-expanded="false"
    aria-controls={`proj-detail-${project.id}`}
  >
    <div class="project-summary-left">
      <div class="project-title-line">
        <span class="project-title">{title}</span>
        {repo && (
          <a
            class="project-ext-link"
            href={repo}
            data-no-toggle
            aria-label="GitHub 저장소"
            title="GitHub"
          >
            <Icon name="github" size={14} /> GitHub ↗
          </a>
        )}
        {extLink && (
          <a
            class="project-ext-link"
            href={extLink.url}
            data-no-toggle
            aria-label={extLink.label}
            title={extLink.label}
          >
            <Icon name="external" size={13} /> {extLink.label} ↗
          </a>
        )}
        <span class="project-year">{year}</span>
      </div>
      <p class="project-brief">{summary}</p>
    </div>
    <div class="project-summary-right">
      {tags.length > 0 && (
        <ul class="tags tag-row-preview">
          {tags.map((t) => <li class="tag tag-interest">{t}</li>)}
        </ul>
      )}
      <span class="chevron" aria-hidden="true">
        <Icon name="chevron" size={14} />
      </span>
    </div>
  </div>

  <div class="project-detail" id={`proj-detail-${project.id}`}>
    <div class="project-detail-inner">
      {(role || collaborators) && (
        <div class="detail-block">
          <p class="detail-label">Role</p>
          <ul class="detail-list">
            {role && <li>{role}</li>}
            {collaborators && <li>협업: {collaborators}</li>}
          </ul>
        </div>
      )}
      {highlights.length > 0 && (
        <div class="detail-block">
          <p class="detail-label">Highlights</p>
          <ul class="detail-list">
            {highlights.map((h) => <li set:html={linkify(h)} />)}
          </ul>
        </div>
      )}
      <div class="detail-block">
        <p class="detail-label">About</p>
        <article class="prose detail-prose">
          <Content />
        </article>
      </div>
    </div>
  </div>
</li>
