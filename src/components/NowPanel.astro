---
import { profile } from '../data/profile';
---

<div class="now-strip">
  <span class="pulse" aria-hidden="true"></span>
  <div class="now-body">
    <b>Currently</b>
    <ul>
      {
        profile.now.map((n) => (
          <li>
            <span class="now-label">{n.label}</span>
            <span class="now-detail">{n.detail}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
