---
// 인라인 SVG 아이콘 셋 — 외부 아이콘 CDN 의존 없이 currentColor로 색을 상속받는다.
// github만 fill 기반(브랜드 로고), 나머지는 stroke 기반 라인 아이콘.
interface Props {
  name: 'mail' | 'github' | 'linkedin' | 'pin' | 'external' | 'cap' | 'trophy' | 'doc' | 'code' | 'chevron';
  size?: number;
}

const { name, size = 16 } = Astro.props;

const icons: Record<Props['name'], { body: string; fill?: boolean }> = {
  mail: {
    body: '<rect x="2.5" y="4.5" width="19" height="15" rx="2.5"/><path d="m3 6 9 7 9-7"/>',
  },
  github: {
    fill: true,
    body: '<path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.1.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.58 9.58 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"/>',
  },
  linkedin: {
    fill: true,
    body: '<path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.64h.05c.53-1 1.83-2.06 3.77-2.06C21.9 8.58 23 10.8 23 14.1V21h-4v-6.14c0-1.46-.03-3.34-2.04-3.34-2.04 0-2.35 1.6-2.35 3.24V21h-4V9Z"/>',
  },
  pin: {
    body: '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.6"/>',
  },
  external: {
    body: '<path d="M14 3h7v7"/><path d="M10 14 21 3"/><path d="M21 13.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.5"/>',
  },
  cap: {
    body: '<path d="m12 4 10 5-10 5L2 9l10-5Z"/><path d="M6 11.5V16c0 1.4 2.7 2.8 6 2.8s6-1.4 6-2.8v-4.5"/><path d="M22 9v5"/>',
  },
  trophy: {
    body: '<path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 4h10v6a5 5 0 0 1-10 0V4Z"/><path d="M7 6H4a1 1 0 0 0-1 1c0 2 1.6 3.4 4 4"/><path d="M17 6h3a1 1 0 0 1 1 1c0 2-1.6 3.4-4 4"/>',
  },
  doc: {
    body: '<path d="M14 2.5H6.5a2 2 0 0 0-2 2v15a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V8L14 2.5Z"/><path d="M14 2.5V8h5.5"/><path d="M9 13h6"/><path d="M9 17h6"/>',
  },
  code: {
    body: '<path d="m8.5 8-5 4 5 4"/><path d="m15.5 8 5 4-5 4"/>',
  },
  chevron: {
    body: '<path d="m6 9 6 6 6-6"/>',
  },
};

const icon = icons[name];
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill={icon.fill ? 'currentColor' : 'none'}
  stroke={icon.fill ? undefined : 'currentColor'}
  stroke-width={icon.fill ? undefined : 1.8}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={icon.body}
/>
